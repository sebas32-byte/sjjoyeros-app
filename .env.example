VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=public-anon-key-replace-me

# Opcional: acceso local al panel admin cuando Supabase Auth no esté disponible.
VITE_ADMIN_EMAIL=admin@sjjoyeros.local
VITE_ADMIN_PASSWORD=change-me

# Copia este archivo a .env y reemplaza con tus credenciales reales.
# Luego arranca el dev server con `npm run dev`.
